# ============================================================
# VARIABLES DE ENTORNO — PRODUCCIÓN
# Hotel Boutique Quinta Vista Verde
# ============================================================
# Copia estos valores en Vercel: Settings → Environment Variables
# Selecciona el entorno "Production" para cada variable.
# ============================================================

# ----------------------------------------------------------
# BASE DE DATOS — Neon PostgreSQL (OBLIGATORIO)
# Obtén esta URL desde: app.neon.tech → tu proyecto → Connection string
# IMPORTANTE: usa el endpoint "-pooler" para funciones serverless de Vercel
# Ejemplo: postgresql://user:pass@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
# ----------------------------------------------------------
DATABASE_URI=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ----------------------------------------------------------
# PAYLOAD CMS SECRET (OBLIGATORIO)
# Genera una clave segura con: openssl rand -base64 32
# Esta clave protege las sesiones del admin. Nunca la compartas.
# ----------------------------------------------------------
PAYLOAD_SECRET=reemplaza-con-valor-de-openssl-rand-base64-32

# ----------------------------------------------------------
# URL PÚBLICA DEL SITIO (OBLIGATORIO)
# Usa tu dominio personalizado. Sin barra final.
# Ejemplos:
#   https://www.hotelquintavistaverde.com
#   https://hotelquintavistaverde.com
# ----------------------------------------------------------
NEXT_PUBLIC_SERVER_URL=https://www.hotelquintavistaverde.com

# ----------------------------------------------------------
# VERCEL BLOB — Almacenamiento de imágenes (OBLIGATORIO)
# Obtén el token desde: Vercel dashboard → Storage → tu Blob store → .env.local
# ----------------------------------------------------------
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXXXXXXXXXXXXXXXXXXXXXX
